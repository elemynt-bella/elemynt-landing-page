---
import "@/styles/index.css";

// Base-aware URLs so assets resolve on both the GitHub Pages project path
// (/landing-page/) and the Plesk root (/). Assets live in public/ and are
// referenced through the base rather than imported, since Astro 5 treats an
// imported .svg as a component, not a URL.
const base = import.meta.env.BASE_URL;
const logoUrl = `${base}logo.svg`;
const faviconUrl = `${base}favicon.svg`;

// ── Animated Multi-Orb Background ────────────────────────────────────────────
// Reproduces the ELEMYNT mesh-gradient background:
//   • Large purple/violet blob — upper center-right
//   • Teal/cyan blob          — right side, mid-height
//   • Yellow/amber blob       — lower right
// Each orb parallax-shifts at a different rate on mousemove for depth (see the
// client script at the bottom of this file).

interface Orb {
  color: string;
  colorMid: string;
  size: string;
  x: number;
  y: number;
  parallax: number;
  blur: number;
  opacity: number;
  breathDuration: number;
  blend?: "screen" | "plus-lighter" | "normal";
  shape?: string;
}

const ORBS: Orb[] = [
  // Upper-left amber/olive wash from the reference, partly tucked under the large dome.
  {
    color: "rgba(255, 190, 55, 0.94)",
    colorMid: "rgba(158, 150, 53, 0.62)",
    size: "clamp(500px, 64vw, 980px)",
    x: 34,
    y: 7,
    parallax: 18,
    blur: 16,
    opacity: 1,
    breathDuration: 9.5,
    blend: "screen",
  },
  // Right-side blue field: the dominant cool glow in the lower-right half.
  {
    color: "rgba(58, 142, 209, 0.62)",
    colorMid: "rgba(27, 92, 176, 0.42)",
    size: "clamp(640px, 66vw, 1040px)",
    x: 78,
    y: 45,
    parallax: 30,
    blur: 20,
    opacity: 0.72,
    breathDuration: 8.5,
    blend: "screen",
  },
  // Lower-left violet fog, broad and low like the screenshot's purple haze.
  {
    color: "rgba(179, 137, 255, 0.72)",
    colorMid: "rgba(103, 81, 180, 0.48)",
    size: "clamp(520px, 56vw, 900px)",
    x: 30,
    y: 78,
    parallax: 24,
    blur: 26,
    opacity: 0.78,
    breathDuration: 10.5,
    blend: "screen",
    shape: "58% 42% 55% 45% / 48% 56% 44% 52%",
  },
  // Small cyan pocket around the lower center-right transition.
  {
    color: "rgba(40, 218, 216, 0.56)",
    colorMid: "rgba(12, 145, 165, 0.36)",
    size: "clamp(300px, 34vw, 540px)",
    x: 70,
    y: 50,
    parallax: 42,
    blur: 24,
    opacity: 0.64,
    breathDuration: 7.5,
    blend: "screen",
  },
  // Faint lavender near the left edge where the large circle crosses the page.
  {
    color: "rgba(156, 119, 255, 0.56)",
    colorMid: "rgba(105, 70, 190, 0.28)",
    size: "clamp(360px, 39vw, 640px)",
    x: 15,
    y: 35,
    parallax: 14,
    blur: 28,
    opacity: 0.58,
    breathDuration: 11,
    blend: "screen",
  },
];

// ── Nav ──────────────────────────────────────────────────────────────────────
type NavLink = { label: string; href: string; external?: boolean; icon?: string };

// Inline lucide icons (stroke inherits currentColor) for the mobile buttons.
const ICON_ATTRS = `width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"`;
const ICON_MAIL = `<svg ${ICON_ATTRS}><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`;
const ICON_BRIEFCASE = `<svg ${ICON_ATTRS}><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>`;
const ICON_BUILDING = `<svg ${ICON_ATTRS}><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/></svg>`;
const ICON_ARROW = `<svg ${ICON_ATTRS.replace('width="18" height="18"', 'width="16" height="16"')}><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`;

const NAV_LINKS: NavLink[] = [
  { label: "Contact", href: "mailto:hello@elemynt.ai", icon: ICON_MAIL },
  { label: "Careers", href: "https://apply.workable.com/xora-innovation", external: true, icon: ICON_BRIEFCASE },
  { label: "Company", href: "https://www.linkedin.com/company/elemynt", external: true, icon: ICON_BUILDING },
];

// ── Feature pills ─────────────────────────────────────────────────────────────
const FEATURES = [
  "Enterprise Compliance",
  "High-throughput Screening",
  "Multi-scale Modeling",
];

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Single violet mark: mid-tone that stays legible on both light and dark
         browser tabs. prefers-color-scheme can't detect the tab-strip color, so
         a theme-swap can't reliably solve this. -->
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Elemynt</title>
    <meta
      name="description"
      content="Elemynt is the materials AI infrastructure layer for industrial R&D — from atomic simulation to deployment, giving research teams the computational infrastructure to move from lab to production."
    />
    <meta name="robots" content="noindex, nofollow" />
    <style>
      html,
      body {
        height: 100%;
        margin: 0;
      }

      /* Below the sm breakpoint (where the nav title hides) the dome becomes a
         smaller circle centered just off the top-right corner: its rim sweeps
         from the top-center down to the right edge (~40% down), matching the
         mobile reference. Only size and left need overriding — the inline
         `top` calc picks up the new --dome-size automatically. */
      @media (max-width: 640px) {
        #dome {
          --dome-size: 128vw !important;
          left: 112% !important;
        }
      }
    </style>
  </head>

  <body>
    <div
      class="relative min-h-screen overflow-hidden"
      style="background: #090b14; font-family: 'DM Sans', system-ui, sans-serif;"
    >
      <!-- ── Animated Multi-Orb Background ── -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden bg-[#090b14]" aria-hidden="true">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_33%_12%,rgba(218,168,48,0.22),transparent_30%),radial-gradient(circle_at_73%_61%,rgba(40,129,190,0.22),transparent_35%),radial-gradient(circle_at_29%_83%,rgba(125,91,178,0.24),transparent_31%),linear-gradient(115deg,#090b14_0%,#11151f_46%,#08101a_100%)]"
        >
        </div>

        {
          ORBS.map((orb, i) => (
            <div
              class="orb absolute will-change-transform"
              data-parallax={orb.parallax}
              style={`left:${orb.x}%;top:${orb.y}%;width:${orb.size};height:${orb.size};translate:-50% -50%;opacity:${orb.opacity};${orb.blur ? `filter:blur(${orb.blur}px);` : ""}mix-blend-mode:${orb.blend ?? "screen"};animation:orb-enter 1.6s ${i * 0.18}s cubic-bezier(0.22, 1, 0.36, 1) both;`}
            >
              <div
                class="absolute inset-0"
                style={`border-radius:${orb.shape ?? "9999px"};animation:orb-breathe ${orb.breathDuration}s ease-in-out infinite;animation-delay:${i * -1.65}s;background:radial-gradient(circle at 47% 45%, ${orb.color} 0%, ${orb.colorMid} 38%, transparent 72%);filter:blur(34px);`}
              />
            </div>
          ))
        }

        {/* The reference's defining shape: a huge cropped circular dome from the top.
            Sized with a floor so it never shrinks away; top offset is a fraction of
            its own size so the same crest stays visible at every width; below 768px
            the center slides right so the dome sits top-right on narrow screens. */}
        <div
          id="dome"
          class="absolute will-change-transform"
          style="--dome-size: clamp(680px, 92vw, 1240px); width: var(--dome-size); height: var(--dome-size); top: calc(var(--dome-size) * -0.61); left: clamp(50%, calc(50% + (768px - 100vw) * 0.4), 78%); translate: -50% 0; animation: fade-in 2s 0.25s ease both;"
        >
          <div
            class="absolute inset-0 rounded-full opacity-[0.9]"
            style={`animation:orb-breathe 12s ease-in-out infinite;background:radial-gradient(ellipse at 29% 22%, rgba(238, 196, 70, 0.74) 0%, rgba(180, 164, 69, 0.48) 26%, transparent 48%),radial-gradient(ellipse at 72% 29%, rgba(117, 158, 220, 0.42) 0%, rgba(72, 108, 187, 0.22) 30%, transparent 52%),radial-gradient(ellipse at 48% 87%, rgba(185, 130, 255, 0.62) 0%, rgba(149, 104, 220, 0.28) 25%, transparent 47%),radial-gradient(ellipse at 50% 57%, rgba(203, 210, 186, 0.20) 0%, rgba(147, 154, 137, 0.10) 28%, transparent 58%),linear-gradient(145deg, rgba(24, 30, 42, 0.14), rgba(125, 135, 164, 0.32) 52%, rgba(42, 87, 151, 0.24));box-shadow:0 82px 140px rgba(106, 94, 202, 0.18), inset 0 -62px 96px rgba(176, 126, 248, 0.18), inset 0 42px 82px rgba(238, 201, 82, 0.18);filter:blur(0.5px) saturate(0.92);`}
          />
          <div
            class="absolute inset-0 rounded-full opacity-[0.34]"
            style="background: linear-gradient(176deg, transparent 0 49%, rgba(9,11,20,0.28) 49.2% 100%); filter: blur(10px);"
          />
        </div>

        {/* Vignettes tuned to leave dark corners and a readable left column. */}
        <div
          class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_33%,rgba(9,11,20,0.30)_72%,rgba(9,11,20,0.92)_100%)]"
        >
        </div>
        <div class="absolute inset-y-0 left-0 w-[30%] bg-gradient-to-r from-[#090b14] via-[#090b14]/55 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 h-[34%] bg-gradient-to-t from-[#090b14] via-[#090b14]/45 to-transparent"></div>
        <div class="absolute inset-x-0 top-0 h-[10%] bg-gradient-to-b from-[#090b14]/80 to-transparent"></div>

        <div
          class="absolute inset-0 opacity-[0.045] mix-blend-overlay"
          style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E&quot;); background-size: 180px 180px;"
        >
        </div>
      </div>

      <!-- ── Content ── -->
      <div class="relative z-10 flex flex-col min-h-screen text-white">
        <!-- Nav -->
        <nav class="animate-fade-up absolute inset-x-0 top-0 sm:static flex items-center justify-between gap-4 pl-8 pr-6 sm:px-8 lg:px-14 py-6 sm:py-6">
          <div class="flex items-center gap-2 sm:gap-2.5">
            <img src={logoUrl} alt="Elemynt" class="h-10 sm:h-7 w-auto opacity-90" />
            <span
              class="hidden sm:inline text-[15px] font-semibold tracking-[0.14em] uppercase text-white/90"
              style="font-family: Figtree, sans-serif;"
            >
              Elemynt
            </span>
          </div>

          {/* Below sm the links leave the nav and render as buttons under the hero. */}
          <div class="hidden sm:flex items-center gap-7 text-[13px] font-medium text-white/50">
            {
              NAV_LINKS.map(({ label, href, external }) => (
                <a
                  href={href}
                  {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                  class="hover:text-white/90 transition-colors duration-200"
                >
                  {label}
                </a>
              ))
            }
          </div>

        </nav>

        <!-- Hero -->
        {/* Mobile: nav and footer are pinned out of flow, so main spans the full
            viewport height and symmetric padding centers the hero with respect
            to the whole screen. The 6rem padding also keeps the content clear
            of the ~5.5rem nav and ~3.5rem footer on short screens. sm+ keeps
            the original weighted-down spacing. */}
        <main class="flex-1 flex flex-col justify-center px-8 lg:px-14 py-24 sm:py-0 sm:pt-4 sm:pb-24">
          <p
            class="animate-fade-up-1 sm:hidden text-[12px] font-semibold uppercase tracking-[0.24em] mb-4"
            style="color: #e9b64a; font-family: Figtree, sans-serif;"
          >
            Elemynt Materials Platform  
          </p>

          <h1
            class="animate-fade-up-1 text-[38px] sm:text-5xl lg:text-[58px] font-medium leading-[1.08] tracking-[-0.02em] text-white mb-6 max-w-2xl"
            style="font-family: Figtree, sans-serif;"
          >
            The materials AI
            <br />
            infrastructure layer
            <br />
            for industrial R&D
          </h1>

          <p
            class="animate-fade-up-2 text-[15px] lg:text-base text-white/48 leading-relaxed max-w-sm mb-10"
            style="font-family: 'DM Sans', sans-serif; color: rgba(240,242,248,0.46);"
          >
            Accelerate discovery. From atomic simulation to deployment, give research teams the
            computational infrastructure to move from lab to production.
          </p>

          {/* Mobile-only: the three nav links as a stack of compact outlined
              buttons — icon, label, then an arrow after a fixed gap. Each
              button takes its natural width (items-start keeps them compact). */}
          <div class="animate-fade-up-3 sm:hidden flex flex-col items-start gap-3 mt-6">
            {
              NAV_LINKS.map(({ label, href, external, icon }) => (
                <a
                  href={href}
                  {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                  class="flex items-center gap-3 text-[15px] font-semibold rounded-lg px-5 py-3.5 transition-colors duration-200 bg-white/[0.04] text-white/90 border border-white/15 hover:border-white/30 hover:bg-white/[0.08]"
                  style="font-family: Figtree, sans-serif;"
                >
                  <span class="opacity-60" set:html={icon} />
                  {label}
                  <span class="opacity-50 ml-6" set:html={ICON_ARROW} />
                </a>
              ))
            }
          </div>
        </main>

        <!-- Feature pills -->
        <div class="animate-fade-in-4 px-8 lg:px-14 pb-8 hidden sm:flex flex-wrap gap-2">
          {
            FEATURES.map((tag) => (
              <span
                class="text-[11px] tracking-wide text-white/32 border border-white/10 rounded-full px-4 py-1.5 hover:border-white/20 hover:text-white/50 transition-all duration-200 cursor-default"
                style="color: rgba(240,242,248,0.3);"
              >
                {tag}
              </span>
            ))
          }
        </div>

        <!-- Footer -->
        <footer class="absolute inset-x-0 bottom-0 sm:static px-8 lg:px-14 py-5 flex items-center justify-between">
          <span class="text-[11px] text-white/25" style="font-family: 'DM Sans', sans-serif;">
            © {currentYear} Elemynt. All Rights Reserved.
          </span>
          <span
            class="hidden sm:inline text-[22px] font-bold tracking-[0.28em] uppercase text-white/60"
            style="font-family: Figtree, sans-serif;"
          >
            ELEMYNT
          </span>
        </footer>
      </div>
    </div>

    <script>
      // Mouse-parallax for the orb background. Each orb drifts at its own rate
      // (data-parallax); the dome drifts subtly. Eased toward the pointer with a
      // requestAnimationFrame lerp. This is the only client JS on the page.
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const orbs = document.querySelectorAll<HTMLElement>(".orb");
      const dome = document.getElementById("dome");
      const target = { x: 0.5, y: 0.5 };
      const current = { x: 0.5, y: 0.5 };

      // Respect the user's reduced-motion preference: skip the pointer-driven
      // parallax loop entirely (the CSS animations are also stilled — see theme.css).
      if (!reduceMotion) {
      window.addEventListener("mousemove", (e) => {
        target.x = e.clientX / window.innerWidth;
        target.y = e.clientY / window.innerHeight;
      });

      const tick = () => {
        current.x += (target.x - current.x) * 0.035;
        current.y += (target.y - current.y) * 0.035;

        const mx = current.x - 0.5;
        const my = current.y - 0.5;

        if (dome) {
          dome.style.transform = `translate(${mx * 12}px, ${my * 10}px)`;
        }

        orbs.forEach((el) => {
          const p = Number(el.dataset.parallax);
          el.style.transform = `translate(${mx * p}px, ${my * p}px)`;
        });

        requestAnimationFrame(tick);
      };
      tick();
      }
    </script>
  </body>
</html>
